# Source: https://github.com/benblasco/backups-personal
[Unit]
Description=Rclone sync personal documents to OneDrive
RequiresMountsFor=/var/mnt/sg1

[Service]
Type=oneshot
ExecStart=rclone sync /var/mnt/sg1/eblaben_backup/personal/ onedrive:rclone_backup/personal/ --log-file=%h/rclone_logs/onedrive-personal.log --log-level=INFO --stats-log-level NOTICE
ExecStopPost=/var/usrlocal/bin/rclone-notify.sh rclone-onedrive-personal %h/rclone_logs/onedrive-personal.log
